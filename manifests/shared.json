{
  "sdkId": "shared",
  "title": "mediasfu-shared",
  "packagePath": "mediasfu-shared",
  "apiDocsTool": "typedoc",
  "capabilities": [
    "conference",
    "webinar",
    "broadcast",
    "chat",
    "recording",
    "whiteboard",
    "translation",
    "screen-share"
  ],
  "criticalTools": [
    "sdk.recommend",
    "app.scaffold",
    "integration.plan",
    "env.preflight",
    "room.bootstrap",
    "feature.map",
    "runtime.diagnose",
    "fix.suggest"
  ],
  "supportTools": [
    "api.build_docs",
    "docs.sync",
    "parity.check",
    "api.reference.search",
    "room.flow.explain",
    "ui.mode.recommend",
    "ui.overrides.guide",
    "security.proxy.rooms",
    "backend.integration.guide",
    "frontend.architecture.plan",
    "headless.integration.plan",
    "widget.integration.plan",
    "telephony.call-control.plan",
    "runtime.readiness.diagnose",
    "lifecycle.cleanup.audit",
    "credential.broker.plan"
  ],
  "toolAdapters": [
    {
      "id": "sdk.recommend",
      "kind": "advisor",
      "profile": "framework-agnostic runtime core"
    },
    {
      "id": "app.scaffold",
      "kind": "scaffold",
      "templates": [
        "socket-manager",
        "event-router",
        "room-state-store"
      ]
    },
    {
      "id": "integration.plan",
      "kind": "planner",
      "checkpoints": [
        "deps-installed",
        "socket-connected",
        "first-room-created"
      ]
    },
    {
      "id": "env.preflight",
      "kind": "command",
      "command": "node -v && npm -v"
    },
    {
      "id": "room.bootstrap",
      "kind": "guide",
      "source": "README.md"
    },
    {
      "id": "feature.map",
      "kind": "mapper",
      "source": "capabilities"
    },
    {
      "id": "runtime.diagnose",
      "kind": "diagnostic",
      "patterns": [
        "ECONNREFUSED",
        "401",
        "socket",
        "mediasoup",
        "transport"
      ]
    },
    {
      "id": "fix.suggest",
      "kind": "remediation",
      "source": "docs/operations"
    },
    {
      "id": "api.build_docs",
      "kind": "npm-script",
      "script": "build-docs"
    },
    {
      "id": "docs.sync",
      "kind": "command",
      "command": "cd website && npm run sync:sdk-docs && npm run sync:api-docs"
    },
    {
      "id": "parity.check",
      "kind": "command",
      "command": "cd website && npm run check:parity-drift"
    },
    {
      "id": "api.reference.search",
      "kind": "reference-search",
      "sources": [
        "website/docs/sdks/shared.md",
        "website/static/api/shared/index.html"
      ],
      "maxResults": 6
    },
    {
      "id": "room.flow.explain",
      "kind": "flow-explainer",
      "flow": {
        "create": [
          "Collect credentials and backend mode",
          "Validate environment and SDK prerequisites",
          "Call create room helper and parse response",
          "Initialize socket/session state",
          "Mount room UI or headless orchestration"
        ],
        "join": [
          "Collect room ID and participant identity",
          "Validate credentials/token and transport reachability",
          "Call join room helper and parse response",
          "Attach media and participant subscriptions",
          "Render room shell and active controls"
        ]
      }
    },
    {
      "id": "ui.mode.recommend",
      "kind": "ui-advisor",
      "modes": [
        "prebuilt",
        "hybrid",
        "headless"
      ]
    },
    {
      "id": "ui.overrides.guide",
      "kind": "ui-overrides",
      "focusAreas": [
        "branding",
        "layout",
        "cards",
        "controls",
        "headless-shell"
      ]
    },
    {
      "id": "security.proxy.rooms",
      "kind": "security-guide",
      "patterns": [
        "proxy-create-room",
        "proxy-join-room",
        "short-lived-token",
        "rate-limit",
        "audit-log"
      ]
    },
    {
      "id": "backend.integration.guide",
      "kind": "knowledge",
      "source": "references/platform/backend-integration.md"
    },
    {
      "id": "frontend.architecture.plan",
      "kind": "architecture-planner",
      "source": "references/platform/production-frontend-patterns.md"
    },
    {
      "id": "headless.integration.plan",
      "kind": "headless-planner",
      "source": "references/platform/production-frontend-patterns.md"
    },
    {
      "id": "widget.integration.plan",
      "kind": "widget-planner",
      "source": "references/platform/production-frontend-patterns.md"
    },
    {
      "id": "telephony.call-control.plan",
      "kind": "telephony-planner",
      "source": "references/platform/production-frontend-patterns.md"
    },
    {
      "id": "runtime.readiness.diagnose",
      "kind": "readiness-diagnostic",
      "source": "references/platform/production-frontend-patterns.md"
    },
    {
      "id": "lifecycle.cleanup.audit",
      "kind": "lifecycle-audit",
      "source": "references/platform/production-frontend-patterns.md"
    },
    {
      "id": "credential.broker.plan",
      "kind": "credential-planner",
      "source": "references/platform/production-frontend-patterns.md"
    }
  ]
}
