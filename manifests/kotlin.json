{
  "sdkId": "kotlin",
  "title": "MediaSFU Kotlin",
  "packagePath": "mediasfu-sdk-kotlin",
  "apiDocsTool": "dokka",
  "capabilities": [
    "conference",
    "webinar",
    "broadcast",
    "chat",
    "recording",
    "whiteboard",
    "translation",
    "screen-share"
  ],
  "criticalTools": [
    "sdk.recommend",
    "app.scaffold",
    "integration.plan",
    "env.preflight",
    "room.bootstrap",
    "feature.map",
    "runtime.diagnose",
    "fix.suggest"
  ],
  "supportTools": [
    "api.build_docs",
    "docs.sync",
    "parity.check",
    "api.reference.search",
    "room.flow.explain",
    "ui.mode.recommend",
    "ui.overrides.guide",
    "security.proxy.rooms"
  ],
  "toolAdapters": [
    {
      "id": "sdk.recommend",
      "kind": "advisor",
      "profile": "Kotlin Android and KMP apps"
    },
    {
      "id": "app.scaffold",
      "kind": "scaffold",
      "templates": [
        "gradle-dependency",
        "compose-room-screen",
        "settings-provider"
      ]
    },
    {
      "id": "integration.plan",
      "kind": "planner",
      "checkpoints": [
        "deps-installed",
        "gradle-sync-ok",
        "first-room-created"
      ]
    },
    {
      "id": "env.preflight",
      "kind": "command",
      "command": "java -version"
    },
    {
      "id": "room.bootstrap",
      "kind": "guide",
      "source": "README.md"
    },
    {
      "id": "feature.map",
      "kind": "mapper",
      "source": "capabilities"
    },
    {
      "id": "runtime.diagnose",
      "kind": "diagnostic",
      "patterns": [
        "gradle",
        "compose",
        "socket",
        "permission",
        "transport"
      ]
    },
    {
      "id": "fix.suggest",
      "kind": "remediation",
      "source": "docs/operations"
    },
    {
      "id": "api.build_docs",
      "kind": "command",
      "command": "./gradlew :shared:dokkaHtml"
    },
    {
      "id": "docs.sync",
      "kind": "command",
      "command": "cd website && npm run sync:sdk-docs && npm run sync:api-docs"
    },
    {
      "id": "parity.check",
      "kind": "command",
      "command": "cd website && npm run check:parity-drift"
    },
    {
      "id": "api.reference.search",
      "kind": "reference-search",
      "sources": [
        "website/docs/sdks/kotlin.md",
        "website/static/api/kotlin/index.html"
      ],
      "maxResults": 6
    },
    {
      "id": "room.flow.explain",
      "kind": "flow-explainer",
      "flow": {
        "create": [
          "Collect credentials and backend mode",
          "Validate environment and SDK prerequisites",
          "Call create room helper and parse response",
          "Initialize socket/session state",
          "Mount room UI or headless orchestration"
        ],
        "join": [
          "Collect room ID and participant identity",
          "Validate credentials/token and transport reachability",
          "Call join room helper and parse response",
          "Attach media and participant subscriptions",
          "Render room shell and active controls"
        ]
      }
    },
    {
      "id": "ui.mode.recommend",
      "kind": "ui-advisor",
      "modes": [
        "prebuilt",
        "hybrid",
        "headless"
      ]
    },
    {
      "id": "ui.overrides.guide",
      "kind": "ui-overrides",
      "focusAreas": [
        "branding",
        "layout",
        "cards",
        "controls",
        "headless-shell"
      ]
    },
    {
      "id": "security.proxy.rooms",
      "kind": "security-guide",
      "patterns": [
        "proxy-create-room",
        "proxy-join-room",
        "short-lived-token",
        "rate-limit",
        "audit-log"
      ]
    }
  ]
}
