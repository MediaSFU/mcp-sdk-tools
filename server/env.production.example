MCP_HOST=127.0.0.1
MCP_PORT=3333
MCP_ENDPOINT=/mcp
MCP_ACTION_ENDPOINT=/mcp/actions
MCP_ALLOW_UNAUTHENTICATED_PUBLIC=1

# Action sessions are validated by MediaSFU using the caller's disposable key.
MCP_MEDIASFU_API_BASE=https://mediasfu.com
MCP_ACTION_ORIGIN=https://mcp.mediasfu.com


# Host header allow-list enforced by the MCP Express app.
MCP_ALLOWED_HOSTS=mcp.mediasfu.com,mediasfu.com

# Default HTTP mode is read-only. Keep this unset in production.
# MCP_HTTP_ALLOW_SIDE_EFFECTS=1

# Rate limit defaults: 120 requests/minute.
MCP_RATE_LIMIT_WINDOW_MS=60000
MCP_RATE_LIMIT_MAX=120
# Conservative initial bounds (15-minute idle expiry, max 250 concurrent sessions).
MCP_SESSION_TTL_MS=900000
MCP_MAX_SESSIONS=250

# Never set MCP_ALLOW_LOCAL_SIDE_EFFECTS on a public/shared service.

# Internal docs build/parity commands are omitted from the public tool list.
# Never enable this on the public hosted service.
# MCP_INCLUDE_INTERNAL_TOOLS=1

# /mcp is intentionally unauthenticated and permanently read-only.
# /mcp/actions always requires Bearer <username>:<disposableKey>.
