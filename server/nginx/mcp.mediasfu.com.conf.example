server {
    listen 80;
    listen [::]:80;
    server_name mcp.mediasfu.com;

    location ^~ /.well-known/acme-challenge/ {
        root /var/www/certbot;
        default_type text/plain;
        try_files $uri =404;
    }

    location / {
        return 301 https://$host$request_uri;
    }
}

server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name mcp.mediasfu.com;

    ssl_certificate /etc/letsencrypt/live/mcp.mediasfu.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/mcp.mediasfu.com/privkey.pem;
    include /etc/letsencrypt/options-ssl-nginx.conf;
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem;

    client_max_body_size 256k;
    access_log /var/log/nginx/mcp.mediasfu.com.access.log;
    error_log /var/log/nginx/mcp.mediasfu.com.error.log warn;

    add_header Strict-Transport-Security "max-age=31536000" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header Referrer-Policy "no-referrer" always;
    add_header Permissions-Policy "camera=(), microphone=(), geolocation=()" always;

    location = / {
        default_type text/plain;
        return 200 "MediaSFU MCP server is running.\nPublic read-only endpoint: /mcp\nAuthenticated actions endpoint: /mcp/actions\nHealth: /healthz\n";
    }

    location = /healthz {
        limit_except GET { deny all; }
        proxy_pass http://127.0.0.1:3333/healthz;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Forwarded-Proto https;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Request-Id $request_id;
        proxy_hide_header X-Powered-By;
    }

    location = /mcp {
        limit_except GET POST DELETE { deny all; }
        proxy_pass http://127.0.0.1:3333/mcp;
        proxy_http_version 1.1;
        proxy_buffering off;
        proxy_request_buffering off;
        proxy_read_timeout 3600s;
        proxy_send_timeout 3600s;
        proxy_set_header Host $host;
        proxy_set_header X-Forwarded-Proto https;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Request-Id $request_id;
        proxy_set_header Authorization $http_authorization;
        proxy_set_header MCP-Session-ID $http_mcp_session_id;
        proxy_set_header MCP-Protocol-Version $http_mcp_protocol_version;
        proxy_set_header Last-Event-ID $http_last_event_id;
        proxy_set_header Connection "";
        proxy_hide_header X-Powered-By;
    }
    location = /mcp/actions {
        limit_except GET POST DELETE { deny all; }
        proxy_pass http://127.0.0.1:3333/mcp/actions;
        proxy_http_version 1.1;
        proxy_buffering off;
        proxy_request_buffering off;
        proxy_read_timeout 3600s;
        proxy_send_timeout 3600s;
        proxy_set_header Host $host;
        proxy_set_header X-Forwarded-Proto https;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Request-Id $request_id;
        proxy_set_header Authorization $http_authorization;
        proxy_set_header MCP-Session-ID $http_mcp_session_id;
        proxy_set_header MCP-Protocol-Version $http_mcp_protocol_version;
        proxy_set_header Last-Event-ID $http_last_event_id;
        proxy_set_header Connection "";
        proxy_hide_header X-Powered-By;
    }


    location / {
        return 404;
    }
}
